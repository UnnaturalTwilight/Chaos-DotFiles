// Zed keymap
//
// For information on binding keys, see the Zed
// documentation: https://zed.dev/docs/key-bindings
//
// To see the default key bindings run `zed: open default keymap`
// from the command palette.
[
  {
    "context": "Workspace",
    "bindings": {
      // "shift shift": "file_finder::Toggle"
    },
  },
  {
    "context": "Editor && vim_mode == insert",
    "bindings": {
      // "j k": "vim::NormalBefore"
    },
  },
  {
    "context": "Terminal",
    "bindings": {
      "ctrl-shift-enter": "pane::SplitRight"
    }
  },
  {
    "context": "Terminal",
    "unbind": {
      "ctrl-shift-5": "pane::SplitRight"
    }
  },
  {
    "context": "Editor && mode == full",
    "unbind": {
      "ctrl-shift-enter": "editor::NewlineAbove"
    }
  },
  {
    "context": "Editor && mode == auto_height",
    "unbind": {
      "ctrl-shift-enter": "editor::NewlineBelow"
    }
  },
  {
    "context": "Editor",
    "bindings": {
      "ctrl-shift-enter": "pane::SplitRight"
    }
  },
  {
    "context": "Editor",
    "unbind": {
      "ctrl-\\": "pane::SplitRight"
    }
  },
  {
    "context": "!Terminal",
    "unbind": {
      "ctrl-shift-c": "collab_panel::ToggleFocus"
    }
  },
  {
    "context": "Editor",
    "bindings": {
      "ctrl-shift-c": "editor::Copy"
    }
  },
  {
    "unbind": {
      "ctrl-q": "zed::Quit"
    }
  },
  {
    "context": "SettingsWindow",
    "bindings": {
      "ctrl-q": "workspace::CloseWindow"
    }
  },
  {
    "context": "SettingsWindow",
    "unbind": {
      "ctrl-w": "workspace::CloseWindow"
    }
  },
  {
    "context": "RulesLibrary",
    "bindings": {
      "ctrl-q": "workspace::CloseWindow"
    }
  },
  {
    "context": "RulesLibrary",
    "unbind": {
      "ctrl-w": "workspace::CloseWindow"
    }
  },
  {
    "context": "Workspace",
    "unbind": {
      "ctrl-w": "workspace::CloseActiveDock"
    }
  },
  {
    "context": "Editor",
    "bindings": {
      "ctrl-q": [
        "pane::CloseActiveItem",
        {
          "close_pinned": false
        }
      ]
    }
  },
  {
    "context": "Terminal",
    "bindings": {
      "ctrl-shift-q": [
        "pane::CloseActiveItem",
        {
          "close_pinned": false
        }
      ]
    }
  },
  {
    "context": "Pane",
    "unbind": {
      "ctrl-w": [
        "pane::CloseActiveItem",
        {
          "close_pinned": false
        }
      ]
    }
  },
  {
    "context": "Editor",
      "bindings": {
      "ctrl-shift-v": "editor::Paste"
    }
  },
  {
    "context": "Editor && extension == svg",
    "unbind": {
      "ctrl-shift-v": "svg::OpenPreview"
    }
  },
  {
    "context": "Editor && extension == md",
    "unbind": {
      "ctrl-shift-v": "markdown::OpenPreview"
    }
  }
]
